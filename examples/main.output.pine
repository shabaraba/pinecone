//@version=5
indicator('My Strategy', overlay = true)

// --- inlined from ./killzone_lib.pinescript ---

// Example killzone library module
// Defines types and functions for ICT killzone detection

type kz_KZ
    line  lnT
    line  lnM
    line  lnB
    label lb

kz_kzColor = input.color(color.new(#00bcd4, 80), 'Killzone Color')
kz_kzShow  = input(true, 'Show Killzones')

method kz_plot(kz_KZ _id, bool _active, float _h, float _l, int _t, color _c) =>
    if _active and not _active[1]
        _id.lnT := line.new(_t, _h, _t, _h, xloc.bar_time, color = _c)
        _id.lnB := line.new(_t, _l, _t, _l, xloc.bar_time, color = _c)
        _id.lb  := label.new(_t, _h, 'KZ', xloc.bar_time, color = color(na), textcolor = _c)

    if _active
        _id.lnT.set_xy2(_t, _h)
        _id.lnB.set_xy2(_t, _l)

var kz_KZ kz_kz = kz_KZ.new()

kz_nySession = not na(time(timeframe.period, '0830-1100', 'UTC-5'))
kz_kz.kz_plot(kz_nySession, high, low, time, kz_kzColor)

// --- end inline ---


// killzone_lib の内容が kz_ プレフィックスでインライン展開される
// kz_plot(...) → kz_plot(...) に変換される
// type KZ     → type kz_KZ に変換される
